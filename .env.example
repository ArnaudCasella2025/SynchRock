# Firebase project config for the shared setlist (Firestore).
# Copy this file to .env.local and fill in the values from your Firebase
# project's web app settings (Project settings → General → Your apps).
# These are not secrets — they identify the project, not grant access;
# actual access is controlled by Firestore security rules.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
